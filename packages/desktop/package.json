{
  "name": "@openchamber/desktop",
  "version": "1.9.1",
  "private": true,
  "type": "module",
  "desktopPrerequisites": [
    "Rust stable toolchain (via rustup)",
    "Xcode Command Line Tools installed",
    "Tauri CLI installed (cargo install tauri-cli@^2)"
  ],
  "scripts": {
    "tauri": "tauri",
    "tauri:dev": "tauri dev --features devtools",
    "tauri:build": "node -e \"delete process.env.CI; require('child_process').execFileSync('bunx', ['tauri','build'], {stdio:'inherit', shell:true})\"",
    "build:sidecar": "node ./scripts/build-sidecar.mjs",
    "build": "bun -e \"process.exit(0)\"",
    "type-check": "bun -e \"process.exit(0)\"",
    "lint": "bun -e \"process.exit(0)\""
  },
  "dependencies": {},
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.3.1",
    "typescript": "~5.8.3"
  }
}
